:global(body.light-mode) .cta-text { color: rgba(0, 0, 0, 0.5); }
:global(body.light-mode) .cta-btn.secondary { background: rgba(0, 0, 0, 0.03); color: #1d1d1f; border-color: rgba(0, 0, 0, 0.1); }

@media (min-width: 1025px) {
  .bento-grid {
    row-gap: 1.01rem;
    column-gap: 1rem;
    align-items: stretch;
  }
  .bento-item {
    padding: 1.29rem 1.16rem;
  }
  .section-label {
