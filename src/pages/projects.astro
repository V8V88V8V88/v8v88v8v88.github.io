---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects, groupByCategory } from '../data/projects';

const projects = await getProjects();
const grouped = groupByCategory(projects);
const languages = new Set(projects.map(p => p.language));
const repoCount = projects.length;
const langCount = languages.size;
---
<BaseLayout
  title="Projects | V8V88V8V88"
  description="All projects by V8V88V8V88 - Open source, tools, apps, and experiments."
  canonical="https://v8v88v8v88.com/projects/"
>
  <main class="projects-page">
    <section class="projects-hero">
      <pre class="hero-ascii">
 ██████╗ ██████╗  ██████╗      ██╗███████╗ ██████╗████████╗███████╗
 ██╔══██╗██╔══██╗██╔═══██╗     ██║██╔════╝██╔════╝╚══██╔══╝██╔════╝
 ██████╔╝██████╔╝██║   ██║     ██║█████╗  ██║        ██║   ███████╗
 ██╔═══╝ ██╔══██╗██║   ██║██   ██║██╔══╝  ██║        ██║   ╚════██║
 ██║     ██║  ██║╚██████╔╝╚█████╔╝███████╗╚██████╗   ██║   ███████║
 ╚═╝     ╚═╝  ╚═╝ ╚═════╝  ╚════╝ ╚══════╝ ╚═════╝   ╚═╝   ╚══════╝
      </pre>
      <p class="hero-tagline">
        That I've built, contributed, and <em>shipped</em>.
      </p>

      <div class="contrib-chart" id="contrib-chart">
        <div class="contrib-header">
          <span class="contrib-count" id="contrib-count"></span>
        </div>
        <div class="contrib-grid" id="contrib-grid"></div>
        <div class="contrib-legend">
          <span class="contrib-legend-label">Less</span>
          <div class="contrib-cell level-0"></div>
          <div class="contrib-cell level-1"></div>
          <div class="contrib-cell level-2"></div>
          <div class="contrib-cell level-3"></div>
          <div class="contrib-cell level-4"></div>
          <span class="contrib-legend-label">More</span>
        </div>
      </div>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-value">{repoCount}+</span>
          <span class="hero-stat-label">Repositories</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">{langCount}+</span>
          <span class="hero-stat-label">Languages</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-value">∞</span>
          <span class="hero-stat-label">Side quests</span>
        </div>
      </div>
      <div class="hero-tech">
        <span class="hero-tech-label">I write in</span>
        <div class="hero-tech-list">
          <span class="tech-pill" data-filter-lang="all">All</span>
          <span class="tech-pill" data-filter-lang="Rust">Rust</span>
          <span class="tech-pill" data-filter-lang="C/C++">C/C++</span>
          <span class="tech-pill" data-filter-lang="Python">Python</span>
          <span class="tech-pill" data-filter-lang="TypeScript">TypeScript</span>
          <span class="tech-pill" data-filter-lang="Svelte">Svelte</span>
          <span class="tech-pill" data-filter-lang="Go">Go</span>
          <span class="tech-pill" data-filter-lang="Shell">Shell</span>
        </div>
      </div>
    </section>

    <div class="projects-divider"></div>

    <div class="filter-controls">
      <button class="filter-btn active" data-filter="all">All Projects</button>
      <button class="filter-btn" data-filter="featured">Featured Only ★</button>
    </div>

    <div class="project-list">
      {grouped.map(group => (
        <Fragment>
          <span class="section-label">{group.category}</span>
          {group.projects.map(project => (
            <a href={project.url} target="_blank" rel="noopener noreferrer"
              class={`project-item${project.featured ? ' featured' : ''}`}
              data-lang={project.langFilter}>
              <div class="project-info">
                <div class="project-name">{project.name}</div>
                <div class="project-desc">{project.description}</div>
              </div>
              <span class="project-lang">{project.language}</span>
              <span class="project-arrow">→</span>
            </a>
          ))}
        </Fragment>
      ))}
    </div>
  </main>

  <script is:inline>
    (function() {
      var chart = document.getElementById('contrib-chart');
      var grid = document.getElementById('contrib-grid');
      var countEl = document.getElementById('contrib-count');
      if (!chart || !grid || !countEl) return;

      fetch('https://github-contributions-api.jogruber.de/v4/V8V88V8V88?y=last')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var contributions = data.contributions || [];
          var total = data.total && data.total.lastYear || 0;
          countEl.textContent = total + ' contributions in the last year';

          if (contributions.length === 0) { chart.style.display = 'none'; return; }

          var weeks = [];
          var week = [];
          var firstDay = new Date(contributions[0].date).getDay();
          for (var i = 0; i < firstDay; i++) week.push({ date: '', count: 0, level: -1 });
          for (var j = 0; j < contributions.length; j++) {
            week.push(contributions[j]);
            if (week.length === 7) { weeks.push(week); week = []; }
          }
          if (week.length > 0) weeks.push(week);

          var frag = document.createDocumentFragment();
          for (var w = 0; w < weeks.length; w++) {
            var weekDiv = document.createElement('div');
            weekDiv.className = 'contrib-week';
            for (var d = 0; d < weeks[w].length; d++) {
              var day = weeks[w][d];
              var cell = document.createElement('div');
              cell.className = 'contrib-cell ' + (day.level === -1 ? 'empty' : 'level-' + day.level);
              if (day.date) cell.title = day.count + ' contributions on ' + day.date;
              weekDiv.appendChild(cell);
            }
            frag.appendChild(weekDiv);
          }
          grid.appendChild(frag);
        })
        .catch(function() { chart.style.display = 'none'; });
    })();
  </script>

  <script is:inline>
    const langMap = {
      'TypeScript': 'TypeScript',
      'Rust': 'Rust',
      'Python': 'Python',
      'Svelte': 'Svelte',
      'Go': 'Go',
      'Shell': 'Shell',
      'C++': 'C/C++',
      'C': 'C/C++',
      'JavaScript': 'Others',
      'HTML': 'Others',
      'Theme': 'Others',
      'Config': 'Others',
      'Jupyter': 'Others',
      'CSS': 'Others',
      'GDScript': 'Others'
    };

    function initializeProjectLangs() {
      const projectItems = document.querySelectorAll('.project-item');
      projectItems.forEach(item => {
        if (!item.dataset.lang) {
          const langSpan = item.querySelector('.project-lang');
          if (langSpan) {
            const langText = langSpan.textContent.trim();
            item.dataset.lang = langMap[langText] || 'Others';
          }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      initializeProjectLangs();

      const filterBtns = document.querySelectorAll('.filter-btn');
      const projectList = document.querySelector('.project-list');
      const techPills = document.querySelectorAll('.tech-pill');

      const allPill = document.querySelector('.tech-pill[data-filter-lang="all"]');
      if (allPill) allPill.classList.add('active');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          const filter = btn.dataset.filter;
          if (filter === 'featured') {
            projectList.classList.add('show-featured-only');
          } else {
            projectList.classList.remove('show-featured-only');
          }
        });
      });

      techPills.forEach(pill => {
        pill.addEventListener('click', (e) => {
          e.stopPropagation();
          const selectedLang = pill.dataset.filterLang;

          techPills.forEach(p => p.classList.remove('active'));
          pill.classList.add('active');

          const projectItems = document.querySelectorAll('.project-item');
          const sectionLabels = document.querySelectorAll('.section-label');
          let hasOthers = false;

          projectItems.forEach(item => {
            const itemLang = item.dataset.lang || 'Others';
            if (selectedLang === 'all' || itemLang === selectedLang) {
              item.style.display = '';
              if (itemLang === 'Others') hasOthers = true;
            } else {
              item.style.display = 'none';
            }
          });

          sectionLabels.forEach(label => {
            const nextItems = [];
            let sibling = label.nextElementSibling;
            while (sibling && !sibling.classList.contains('section-label')) {
              if (sibling.classList.contains('project-item')) {
                nextItems.push(sibling);
              }
              sibling = sibling.nextElementSibling;
            }

            const hasVisible = nextItems.some(item => item.style.display !== 'none');
            label.style.display = hasVisible ? '' : 'none';
          });

          if (selectedLang === 'all' || selectedLang === 'Others') {
            let othersSection = document.querySelector('.section-label[data-section="others"]');
            const othersProjects = Array.from(projectItems).filter(item =>
              item.dataset.lang === 'Others' && item.style.display !== 'none'
            );

            if (!othersSection && othersProjects.length > 0) {
              othersSection = document.createElement('span');
              othersSection.className = 'section-label';
              othersSection.setAttribute('data-section', 'others');
              othersSection.textContent = 'Others';

              if (othersProjects[0]) {
                othersProjects[0].parentNode.insertBefore(othersSection, othersProjects[0]);
              }
            } else if (othersSection && othersProjects.length === 0) {
              othersSection.remove();
            }
          } else {
            const othersSection = document.querySelector('.section-label[data-section="others"]');
            if (othersSection) othersSection.remove();
          }
        });
      });
    });
  </script>
</BaseLayout>

<style>
.projects-page {
  min-height: 100vh;
  padding: 0 2rem 4rem;
  max-width: 900px;
  margin: 0 auto;
}

.projects-hero {
  min-height: auto;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  padding: 120px 0 2.5rem;
  position: relative;
}

.hero-ascii {
  font-family: 'JetBrains Mono', monospace;
  font-size: clamp(0.35rem, 1vw, 0.55rem);
  line-height: 1.1;
  color: #1DB954;
  white-space: pre;
  margin-bottom: 2rem;
  opacity: 0.9;
  text-shadow: 0 0 20px rgba(29, 185, 84, 0.4);
}

.hero-tagline {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  font-weight: 400;
  color: #fff;
  max-width: 600px;
  line-height: 1.6;
  letter-spacing: 0.01em;
  margin-bottom: 1.5rem;
}

.hero-tagline em {
  font-style: italic;
  color: #1DB954;
}

.hero-stats {
  display: flex;
  gap: 3rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.5);
}

.hero-stat {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.hero-stat-value {
  font-size: 1.5rem;
  font-weight: 500;
  line-height: 1.3;
  color: #fff;
}

.hero-stat-label {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  line-height: 1.4;
  color: rgba(255, 255, 255, 0.4);
}

.hero-tech {
  margin-top: 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.hero-tech-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: rgba(255, 255, 255, 0.35);
}

.hero-tech-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.tech-pill {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  padding: 0.35rem 0.75rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 100px;
  color: rgba(255, 255, 255, 0.6);
  transition: all 0.2s ease;
  cursor: pointer;
}

.tech-pill:hover {
  background: rgba(29, 185, 84, 0.1);
  border-color: rgba(29, 185, 84, 0.3);
  color: #1DB954;
}

.tech-pill.active {
  background: rgba(29, 185, 84, 0.15);
  border-color: rgba(29, 185, 84, 0.3);
  color: #1DB954;
}

.projects-divider {
  width: 100%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1) 20%, rgba(255, 255, 255, 0.1) 80%, transparent);
  margin-bottom: 2rem;
}

.filter-controls {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 2rem;
}

.filter-btn {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  padding: 0.5rem 1rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 100px;
  color: rgba(255, 255, 255, 0.6);
  cursor: pointer;
  transition: all 0.2s ease;
}

.filter-btn:hover {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.8);
}

.filter-btn.active {
  background: rgba(29, 185, 84, 0.15);
  border-color: rgba(29, 185, 84, 0.3);
  color: #1DB954;
}

.project-list.show-featured-only .project-item:not(.featured) {
  display: none;
}

.project-list.show-featured-only .section-label {
  display: none;
}

.project-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.project-item {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 1.5rem;
  align-items: center;
  padding: 1rem 1rem;
  margin: 0 -1rem;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.2s ease;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.project-item:hover {
  background: rgba(29, 185, 84, 0.08);
}

.project-info {
  min-width: 0;
}

.project-name {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1rem;
  font-weight: 500;
  color: #fff;
  margin-bottom: 0.35rem;
  line-height: 1.5;
  letter-spacing: 0;
  transition: color 0.2s ease;
}

.project-item:hover .project-name {
  color: #1DB954;
}

.project-desc {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 0.875rem;
  line-height: 1.6;
  letter-spacing: 0.01em;
  color: rgba(255, 255, 255, 0.6);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.project-lang {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
  padding: 0.35rem 0.75rem;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 100px;
  white-space: nowrap;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.project-arrow {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.3);
  transition: all 0.2s ease;
}

.project-item:hover .project-arrow {
  color: #1DB954;
  transform: translateX(4px);
}

.project-item.featured {
  border-radius: 8px;
  margin: 0 -1rem;
  padding: 1rem 1rem;
}

.project-item.featured .project-name::after {
  content: '★';
  margin-left: 0.5rem;
  font-size: 0.8rem;
  color: #1DB954;
}

.project-list.show-featured-only .project-item.featured {
  background: rgba(29, 185, 84, 0.08);
  border: 1px solid rgba(29, 185, 84, 0.15);
  border-radius: 10px;
  margin: 0.25rem -1rem;
  padding: 1rem 1rem;
}

.project-list.show-featured-only .project-item.featured .project-name {
  color: #1DB954;
}

.project-list.show-featured-only .project-item.featured:hover {
  background: rgba(29, 185, 84, 0.12);
  border-color: rgba(29, 185, 84, 0.25);
}

.section-label {
  display: block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  font-weight: 500;
  color: #1DB954;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin: 2rem 0 0.75rem;
  padding: 1.5rem 0 0.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.section-label:first-child {
  border-top: none;
  padding-top: 0;
  margin-top: 0;
}

:global(body.light-mode) .hero-ascii {
  color: #0f4d1f;
  text-shadow: none;
}

:global(body.light-mode) .hero-tagline {
  color: #1d1d1f;
}

:global(body.light-mode) .hero-tagline em {
  color: #0f4d1f;
}

:global(body.light-mode) .hero-stat-value {
  color: #1d1d1f;
}

:global(body.light-mode) .hero-stat-label {
  color: rgba(0, 0, 0, 0.4);
}

:global(body.light-mode) .hero-tech-label {
  color: rgba(0, 0, 0, 0.35);
}

:global(body.light-mode) .tech-pill {
  background: rgba(0, 0, 0, 0.04);
  border-color: rgba(0, 0, 0, 0.08);
  color: rgba(0, 0, 0, 0.6);
}

:global(body.light-mode) .tech-pill:hover {
  background: rgba(29, 185, 84, 0.08);
  border-color: rgba(15, 77, 31, 0.3);
  color: #0f4d1f;
}

:global(body.light-mode) .tech-pill.active {
  background: rgba(29, 185, 84, 0.1);
  border-color: rgba(15, 77, 31, 0.3);
  color: #0f4d1f;
}

:global(body.light-mode) .project-item.featured .project-name::after {
  color: #0f4d1f;
}

:global(body.light-mode) .project-list.show-featured-only .project-item.featured {
  background: rgba(29, 185, 84, 0.06);
  border-color: rgba(15, 77, 31, 0.15);
}

:global(body.light-mode) .project-list.show-featured-only .project-item.featured .project-name {
  color: #0f4d1f;
}

:global(body.light-mode) .project-list.show-featured-only .project-item.featured:hover {
  background: rgba(29, 185, 84, 0.1);
  border-color: rgba(15, 77, 31, 0.25);
}

:global(body.light-mode) .projects-divider {
  background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.1) 20%, rgba(0, 0, 0, 0.1) 80%, transparent);
}

:global(body.light-mode) .filter-btn {
  background: rgba(0, 0, 0, 0.04);
  border-color: rgba(0, 0, 0, 0.1);
  color: rgba(0, 0, 0, 0.6);
}

:global(body.light-mode) .filter-btn:hover {
  background: rgba(0, 0, 0, 0.06);
  color: rgba(0, 0, 0, 0.8);
}

:global(body.light-mode) .filter-btn.active {
  background: rgba(29, 185, 84, 0.1);
  border-color: rgba(15, 77, 31, 0.3);
  color: #0f4d1f;
}

:global(body.light-mode) .project-item {
  border-bottom-color: rgba(0, 0, 0, 0.05);
}

:global(body.light-mode) .project-item:hover {
  background: rgba(29, 185, 84, 0.06);
}

:global(body.light-mode) .project-name {
  color: #1d1d1f;
}

:global(body.light-mode) .project-item:hover .project-name {
  color: #0f4d1f;
}

:global(body.light-mode) .project-desc {
  color: rgba(0, 0, 0, 0.6);
}

:global(body.light-mode) .project-lang {
  color: rgba(0, 0, 0, 0.7);
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.1);
}

:global(body.light-mode) .project-arrow {
  color: rgba(0, 0, 0, 0.3);
}

:global(body.light-mode) .project-item:hover .project-arrow {
  color: #0f4d1f;
}

:global(body.light-mode) .section-label {
  color: #0f4d1f;
  border-top-color: rgba(0, 0, 0, 0.08);
}

@media (max-width: 768px) {
  .projects-page {
    padding: 0 1.5rem 3rem;
  }

  .projects-hero {
    padding: 100px 0 2rem;
  }

  .hero-ascii {
    font-size: 0.3rem;
  }

  .hero-stats {
    gap: 2rem;
  }

  .hero-stat-value {
    font-size: 1.25rem;
  }

  .hero-tech {
    margin-top: 1.5rem;
  }

  .tech-pill {
    font-size: 0.65rem;
    padding: 0.3rem 0.6rem;
  }

  .project-item {
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 0.85rem 0.75rem;
    margin: 0 -0.75rem;
  }

  .project-lang {
    display: none;
  }

  .project-name {
    font-size: 0.95rem;
  }

  .project-desc {
    font-size: 0.8rem;
  }
}

@media (max-width: 480px) {
  .projects-page {
    padding: 0 1rem 2rem;
  }

  .projects-hero {
    padding: 90px 0 1.5rem;
  }

  .hero-ascii {
    font-size: 0.22rem;
    margin-bottom: 1.5rem;
  }

  .hero-tagline {
    font-size: 1.25rem;
  }

  .hero-stats {
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .hero-stat-value {
    font-size: 1.1rem;
  }

  .hero-stat-label {
    font-size: 0.6rem;
  }

  .hero-tech {
    margin-top: 1rem;
  }

  .hero-tech-label {
    font-size: 0.6rem;
  }

  .tech-pill {
    font-size: 0.6rem;
    padding: 0.25rem 0.5rem;
  }

  .project-item {
    padding: 0.75rem 0.5rem;
    margin: 0 -0.5rem;
  }

  .project-name {
    font-size: 0.9rem;
  }

  .project-desc {
    font-size: 0.75rem;
  }
}

.contrib-chart {
  margin: 1rem 0 1rem;
  width: 100%;
  max-width: 780px;
  overflow: hidden;
}

.contrib-header {
  margin-bottom: 0.75rem;
}

.contrib-count {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.01em;
}

:global(.contrib-grid) {
  display: grid;
  grid-template-columns: repeat(53, 1fr);
  gap: 2px;
