  <script is:inline>
    const langMap = {
      'TypeScript': 'TypeScript',
      'Rust': 'Rust',
      'Python': 'Python',
      'Svelte': 'Svelte',
      'Go': 'Go',
      'Shell': 'Shell',
      'C++': 'C/C++',
      'C': 'C/C++',
      'JavaScript': 'Others',
      'HTML': 'Others',
      'Theme': 'Others',
      'Config': 'Others',
      'Jupyter': 'Others',
      'CSS': 'Others',
      'GDScript': 'Others'
    };

    function initializeProjectLangs() {
      const projectItems = document.querySelectorAll('.project-item');
      projectItems.forEach(item => {
        if (!item.dataset.lang) {
          const langSpan = item.querySelector('.project-lang');
          if (langSpan) {
            const langText = langSpan.textContent.trim();
            item.dataset.lang = langMap[langText] || 'Others';
          }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      initializeProjectLangs();

      const filterBtns = document.querySelectorAll('.filter-btn');
      const projectList = document.querySelector('.project-list');
      const techPills = document.querySelectorAll('.tech-pill');

      const allPill = document.querySelector('.tech-pill[data-filter-lang="all"]');
      if (allPill) allPill.classList.add('active');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          const filter = btn.dataset.filter;
          if (filter === 'featured') {
            projectList.classList.add('show-featured-only');
          } else {
            projectList.classList.remove('show-featured-only');
          }
        });
      });

      techPills.forEach(pill => {
        pill.addEventListener('click', (e) => {
          e.stopPropagation();
          const selectedLang = pill.dataset.filterLang;

          techPills.forEach(p => p.classList.remove('active'));
          pill.classList.add('active');

          const projectItems = document.querySelectorAll('.project-item');
          const sectionLabels = document.querySelectorAll('.section-label');
          let hasOthers = false;

          projectItems.forEach(item => {
            const itemLang = item.dataset.lang || 'Others';
            if (selectedLang === 'all' || itemLang === selectedLang) {
              item.style.display = '';
              if (itemLang === 'Others') hasOthers = true;
            } else {
              item.style.display = 'none';
            }
          });

          sectionLabels.forEach(label => {
            const nextItems = [];
            let sibling = label.nextElementSibling;
            while (sibling && !sibling.classList.contains('section-label')) {
              if (sibling.classList.contains('project-item')) {
                nextItems.push(sibling);
              }
              sibling = sibling.nextElementSibling;
            }

            const hasVisible = nextItems.some(item => item.style.display !== 'none');
            label.style.display = hasVisible ? '' : 'none';
          });

          if (selectedLang === 'all' || selectedLang === 'Others') {
            let othersSection = document.querySelector('.section-label[data-section="others"]');
            const othersProjects = Array.from(projectItems).filter(item =>
              item.dataset.lang === 'Others' && item.style.display !== 'none'
            );

            if (!othersSection && othersProjects.length > 0) {
              othersSection = document.createElement('span');
              othersSection.className = 'section-label';
              othersSection.setAttribute('data-section', 'others');
              othersSection.textContent = 'Others';

              if (othersProjects[0]) {
                othersProjects[0].parentNode.insertBefore(othersSection, othersProjects[0]);
              }
            } else if (othersSection && othersProjects.length === 0) {
              othersSection.remove();
            }
          } else {
            const othersSection = document.querySelector('.section-label[data-section="others"]');
            if (othersSection) othersSection.remove();
          }
        });
      });
    });
  </script>
</BaseLayout>

