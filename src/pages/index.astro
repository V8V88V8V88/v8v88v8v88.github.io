---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllPosts, formatDate } from '../data/posts';
import { contactPageContacts, getSameAsUrls } from '../data/contacts';
import { getProjects } from '../data/projects';

const posts = getAllPosts();
const allProjects = await getProjects();
const homepageOrder = ['XE', 'indx', 'GNOME-bluetooth-battery-monitor', 'MarkView', 'MarkVue'];
const featuredProjects = [...allProjects]
  .sort((a, b) => {
    const aIndex = homepageOrder.findIndex(name => name.toLowerCase() === a.name.toLowerCase());
    const bIndex = homepageOrder.findIndex(name => name.toLowerCase() === b.name.toLowerCase());

    if (aIndex !== -1 || bIndex !== -1) {
      if (aIndex === -1) return 1;
      if (bIndex === -1) return -1;
      return aIndex - bIndex;
    }

    if (a.image !== b.image) return a.image ? -1 : 1;
    if (a.featured !== b.featured) return a.featured ? -1 : 1;
    return b.stars - a.stars;
  })
  .slice(0, 6);
---
<BaseLayout
  title="V8V88V8V88 | Vaibhav Pratap Singh"
  description="Developer, Linux enthusiast, and open source contributor. Building things with Rust, C++, TypeScript & more."
  canonical="https://v8v88v8v88.com/"
  twitterSite="@v8v88v8v88"
  twitterCreator="@v8v88v8v88"
  showRss={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://v8v88v8v88.com/",
      "name": "V8V88V8V88"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "url": "https://v8v88v8v88.com/",
      "name": "Vaibhav Pratap Singh",
      "alternateName": "V8V88V8V88",
      "jobTitle": "Developer & Open Source Contributor",
      "image": "https://v8v88v8v88.com/images/image.webp",
      "sameAs": getSameAsUrls(),
      "knowsAbout": ["Linux", "FOSS", "Computer Science", "Software Development", "Design"]
    })} />
  </Fragment>

  <main>
    <section class="hero">
      <h1>$ &gt;[V8V88V8V88]_</h1>
      <div class="hero-cli-slot">
        <div class="cli-cmd" data-cmd="curl https://v8v88v8v88.com/api/cli" title="Click to copy">
          <span class="cli-prompt">$</span>
          <span class="cli-text">curl v8v88v8v88.com/api/cli</span>
          <i class="cli-icon fas fa-copy"></i>
        </div>
      </div>
    </section>

    <section class="intro">
      <div class="intro-content">
        <div class="avatar-flip" id="avatar-flip">
          <div class="avatar-inner">
            <img src="/images/image.webp" alt="Vaibhav" class="avatar-front" />
            <img src="/images/V8.webp" alt="V8" class="avatar-back" />
          </div>
        </div>
        <div class="intro-text">
          <h2>
            Hey, I'm
            <span class="vaibhav-hover" role="button" tabindex="0" aria-pressed="false" data-default="Vaibhav" data-alt="V8">Vaibhav</span>
          </h2>
        </div>
      </div>
    </section>

    <p class="now-status">~ cs student. ceh certified. into linux, foss, design and low-level systems</p>

    <section class="about">
      <h2>About Me</h2>
      <p>
        Hey, I'm <span>Vaibhav</span>. Most people online know me as <span>V8</span>.

        I'm a CS student from India, and computers have been a genuine obsession for as long as I can remember. Not just using them, but understanding what's actually going on underneath. That curiosity is what pulled me toward <a href="https://en.wikipedia.org/wiki/Linux" target="_blank" rel="noopener noreferrer">Linux</a>, <a href="https://en.wikipedia.org/wiki/Free_and_open-source_software" target="_blank" rel="noopener noreferrer">FOSS</a>, <a href="https://en.wikipedia.org/wiki/Systems_programming" target="_blank" rel="noopener noreferrer">Systems programming</a>, and lately, <a href="https://www.rust-lang.org/" target="_blank" rel="noopener noreferrer">Rust</a>.
      </p>
      <p>
        Most of how I build and learn comes down to keeping things simple and purposeful. <a href="https://principles-wiki.net/principles:keep_it_simple_stupid" target="_blank" rel="noopener noreferrer">KISS</a> and the <a href="https://en.wikipedia.org/wiki/Unix_philosophy" target="_blank" rel="noopener noreferrer">Unix philosophy</a> just make sense to me. <a href="https://en.wikipedia.org/wiki/Solution_stack" target="_blank" rel="noopener noreferrer">Full-stack dev</a> came along out of necessity and freelance work. Graphic design and video editing just kind of happened. as they do when you spend enough time across different corners of the computer <i>ki duniya</i>.
      </p>
      <p>
        Outside of code, I read a lot (or try to). philosophy, history, geography, science. Wherever curiosity takes me.
      </p>
      <p>
        If you want to get in touch, feel free to reach out through any of my <a href="/contact/">social handles</a>. I'll get back to you, just maybe not instantly.
      </p>
      <a href="https://drive.google.com/file/d/1iQFjSzPWcSA3sAt4WS-uKIUd7ReCz_hz/view?usp=sharing" class="resume-button" target="_blank" rel="noopener noreferrer">Resume</a>
    </section>

    <div class="stats-row">
      <span>~ 8+ years in the game</span>
      <span class="stats-dot">·</span>
      <span>{allProjects.length}+ projects</span>
      <span class="stats-dot">·</span>
      <a href="https://github.com/v8v88v8v88" target="_blank" rel="noopener noreferrer" class="github-link">visit my github </a>
      <span>~</span>
    </div>

    <section class="projects">
      <div class="section-header">
        <h2>Projects</h2>
        <a href="/projects/" class="view-all">view all →</a>
      </div>
      <ul>
        {featuredProjects.map(project => (
          <li class="project-item">
            <a href={project.url} target="_blank" rel="noopener noreferrer">
              {project.image ? (
                <img src={project.image} alt={`${project.name} project cover`} loading="lazy" class="project-thumb" />
              ) : (
                <div class="project-thumb project-thumb-placeholder" aria-hidden="true"></div>
              )}
              <div class="project-meta">
                <h3>{project.name}</h3>
                <span class="project-stack-tag">{project.language}</span>
              </div>
              <p>{project.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="posts">
      <div class="section-header">
        <h2>Blogs</h2>
        <a href="/blogs/" class="view-all">view all →</a>
      </div>
      <ul>
        {posts.map((post, i) => (
          <li>
            <a href={`/${post.slug}/`}>
              <h3>{post.title}{i === 0 && <span class="latest-tag">latest</span>}</h3>
              <p>{post.description}</p>
              <small><time>{formatDate(post.date)}</time></small>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="contact">
      <div class="section-header">
        <h2>Connect</h2>
        <a href="/contact/" class="view-all">view all →</a>
      </div>
      <div class="contact-grid">
        {contactPageContacts.map((c) => (
          <a href={c.url} target={c.url.startsWith('mailto:') ? undefined : '_blank'} rel={c.rel ? `${c.rel} noopener noreferrer` : 'noopener noreferrer'} class="contact-card">
            <i class={`${c.icon} contact-icon`}></i>
            <span>{c.label}</span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    var vaibhavHover = document.querySelector(".vaibhav-hover");
    var avatarFlip = document.getElementById("avatar-flip");
    var vaibhavLocked = false;

    function setVaibhavState(active) {
      if (!vaibhavHover) return;
      vaibhavHover.classList.toggle("is-alt", active);
      vaibhavHover.setAttribute("aria-pressed", String(active));
      vaibhavHover.textContent = active ? (vaibhavHover.getAttribute("data-alt") || "V8") : (vaibhavHover.getAttribute("data-default") || "Vaibhav");
      if (avatarFlip) avatarFlip.classList.toggle("flipped", active);
    }

    function toggleVaibhavState() {
      if (!vaibhavHover) return;
      var nextActive = !vaibhavHover.classList.contains("is-alt");
      vaibhavLocked = nextActive;
      setVaibhavState(nextActive);
    }

    if (vaibhavHover) {
      vaibhavHover.addEventListener("mouseenter", function() {
        if (!vaibhavLocked) setVaibhavState(true);
      });
      vaibhavHover.addEventListener("mouseleave", function() {
        if (!vaibhavLocked) setVaibhavState(false);
      });
      vaibhavHover.addEventListener("click", function() {
        toggleVaibhavState();
      });
      vaibhavHover.addEventListener("keydown", function(e) {
        if (e.key !== "Enter" && e.key !== " ") return;
        e.preventDefault();
        toggleVaibhavState();
      });
    }
    if (avatarFlip) {
      avatarFlip.addEventListener("click", function() {
        toggleVaibhavState();
      });
    }

    var projectsContainer = document.querySelector(".projects ul");
    if (projectsContainer) {
      var leftArrow = document.createElement("div");
      var rightArrow = document.createElement("div");
      leftArrow.classList.add("arrow", "left");
      rightArrow.classList.add("arrow", "right");
      leftArrow.innerHTML = '<i class="fas fa-chevron-left"></i>';
      rightArrow.innerHTML = '<i class="fas fa-chevron-right"></i>';
      document.querySelector(".projects").prepend(leftArrow);
      document.querySelector(".projects").append(rightArrow);
      leftArrow.addEventListener("click", function() { projectsContainer.scrollLeft -= projectsContainer.offsetWidth; });
      rightArrow.addEventListener("click", function() { projectsContainer.scrollLeft += projectsContainer.offsetWidth; });

      function updateArrows() {
        var maxScrollLeft = projectsContainer.scrollWidth - projectsContainer.clientWidth;
        var canScroll = maxScrollLeft > 2;
        if (!canScroll) {
          leftArrow.classList.add("hidden");
          rightArrow.classList.add("hidden");
          return;
        }
        leftArrow.classList.toggle("hidden", projectsContainer.scrollLeft <= 2);
        rightArrow.classList.toggle("hidden", projectsContainer.scrollLeft >= maxScrollLeft - 2);
      }

      projectsContainer.addEventListener("scroll", updateArrows, { passive: true });
      window.addEventListener("resize", updateArrows);
      updateArrows();
    }
    var cliCmd = document.querySelector(".cli-cmd");
    var heroH1 = document.querySelector(".hero h1");
    var heroTapCount = 0;
    var audioCtx;
    function playPop(kind) {
      try {
        if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        if (audioCtx.state === "suspended") audioCtx.resume();
        var t = audioCtx.currentTime;
        var osc = audioCtx.createOscillator();
        var gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.type = "triangle";
        var f0, f1, dur, vol;
        if (kind === "tap") {
          f0 = 360; f1 = 250; dur = 0.09; vol = 0.08;
        } else if (kind === "show") {
          f0 = 640; f1 = 820; dur = 0.12; vol = 0.085;
        } else {
          f0 = 420; f1 = 260; dur = 0.13; vol = 0.085;
        }
        osc.frequency.setValueAtTime(f0, t);
        osc.frequency.exponentialRampToValueAtTime(f1, t + dur);
        gain.gain.setValueAtTime(vol, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + dur);
        osc.start(t);
        osc.stop(t + dur);
      } catch (_) {}
    }
    if (heroH1 && cliCmd) {
      heroH1.addEventListener("click", function() {
        if (cliCmd.classList.contains("hiding")) return;
        var showing = cliCmd.classList.contains("revealed");
        heroTapCount++;
        heroH1.classList.remove("tap-pulse");
        void heroH1.offsetWidth;
        heroH1.classList.add("tap-pulse");
        if (heroTapCount < 2) {
          playPop("tap");
          return;
        }
        heroTapCount = 0;
        playPop("tap");
        if (showing) {
          cliCmd.classList.remove("revealed");
          cliCmd.classList.add("hiding");
          setTimeout(function() { playPop("hide"); }, 220);
          cliCmd.addEventListener("animationend", function handler(e) {
            if (e.target !== cliCmd) return;
            cliCmd.classList.remove("hiding");
            heroH1.classList.remove("shimmer-off");
            cliCmd.removeEventListener("animationend", handler);
          });
        } else {
          cliCmd.classList.remove("hiding");
          cliCmd.classList.add("revealed");
          heroH1.classList.add("shimmer-off");
          setTimeout(function() { playPop("show"); }, 220);
        }
      });
    }
    if (cliCmd) {
      var cliText = cliCmd.querySelector(".cli-text");
      var cliIcon = cliCmd.querySelector(".cli-icon");
      var originalText = cliText.textContent;
      var copying = false;
      cliCmd.addEventListener("click", async function() {
        if (copying) return;
        copying = true;
        try {
          await navigator.clipboard.writeText(cliCmd.getAttribute("data-cmd"));
          cliText.textContent = "copied!";
          cliIcon.classList.remove("fa-copy");
          cliIcon.classList.add("fa-check");
          cliCmd.classList.add("copied");
          setTimeout(function() {
            cliText.textContent = originalText;
            cliIcon.classList.remove("fa-check");
            cliIcon.classList.add("fa-copy");
            cliCmd.classList.remove("copied");
            copying = false;
          }, 1500);
        } catch (_) { copying = false; }
      });
    }
  </script>
</BaseLayout>

<style>
  .hero {
    display: grid;
    justify-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0 0.25rem;
    margin-bottom: 0.6rem;
  }
  .hero-cli-slot {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 1.35rem;
    width: 100%;
  }
  :global(main) .intro {
    margin-top: 0;
  }
  .hero h1 {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.5) 0%,
      rgba(255, 255, 255, 0.5) 40%,
      rgba(255, 255, 255, 1) 44%,
      rgba(255, 255, 255, 1) 56%,
      rgba(255, 255, 255, 0.5) 60%,
      rgba(255, 255, 255, 0.5) 100%
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: titleShimmer 6s linear infinite;
    cursor: pointer;
    user-select: none;
    transition: transform 0.1s ease;
  }
  .hero h1:active {
    transform: scale(0.985);
  }
  .hero h1.tap-pulse {
    animation: titleShimmer 6s linear infinite, tapFlash 0.4s ease-out;
  }
  .hero h1.shimmer-off {
    animation: none;
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
    -webkit-text-fill-color: unset;
    color: rgba(255, 255, 255, 0.85);
  }
  .hero h1.shimmer-off.tap-pulse {
    animation: tapFlash 0.4s ease-out;
  }
  @keyframes tapFlash {
    0% { filter: brightness(1.35); }
    100% { filter: brightness(1); }
  }
  :global(body.light-mode) .hero h1 {
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0.5) 40%,
      rgba(0, 0, 0, 1) 44%,
      rgba(0, 0, 0, 1) 56%,
      rgba(0, 0, 0, 0.5) 60%,
      rgba(0, 0, 0, 0.5) 100%
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  :global(body.light-mode) .hero h1.shimmer-off {
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
    -webkit-text-fill-color: unset;
    color: rgba(0, 0, 0, 0.8);
  }
  .hero h1::after {
    content: '';
    display: inline-block;
    width: 2px;
    height: 0.85em;
    background: #1DB954;
    margin-left: 2px;
    animation: blink 1s step-end infinite;
    vertical-align: baseline;
    border-radius: 1px;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  @keyframes titleShimmer {
    0% { background-position: 200% center; }
    100% { background-position: -100% center; }
  }
  .cli-cmd {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'SF Mono', 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 100px;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    user-select: none;
    transition: background 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
    max-width: 90vw;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .cli-cmd.revealed {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    animation: revealPill 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  .cli-cmd.revealed .cli-text {
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.25) 0%,
      rgba(255, 255, 255, 0.25) 40%,
      rgba(255, 255, 255, 0.95) 44%,
      rgba(255, 255, 255, 0.95) 56%,
      rgba(255, 255, 255, 0.25) 60%,
      rgba(255, 255, 255, 0.25) 100%
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: pillTextShimmer 6s linear infinite;
  }
  .cli-cmd.hiding {
    visibility: visible;
    pointer-events: none;
    animation: hidePill 0.3s ease-in forwards;
  }
  @keyframes pillTextShimmer {
    0% { background-position: 200% center; }
    100% { background-position: -100% center; }
  }
  @keyframes revealPill {
    from {
      opacity: 0;
      transform: translateY(-6px) scale(0.95);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }
  @keyframes hidePill {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
    to {
      opacity: 0;
      transform: translateY(-6px) scale(0.95);
      filter: blur(4px);
    }
  }
  .cli-cmd::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.4s ease;
    box-shadow: 0 0 20px rgba(29, 185, 84, 0.4), inset 0 0 12px rgba(29, 185, 84, 0.1);
    pointer-events: none;
    z-index: 2;
  }
  .cli-cmd:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.28);
  }
  .cli-cmd.copied {
    border-color: rgba(29, 185, 84, 0.3);
    background: rgba(29, 185, 84, 0.06);
  }
  .cli-cmd.copied::after {
    opacity: 1;
    animation: glowPulse 0.6s ease-out;
  }
  @keyframes glowPulse {
    0% { opacity: 0; transform: scale(0.95); }
    40% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.05); }
  }
  .cli-prompt {
    color: #1DB954;
    font-weight: 600;
  }
  .cli-text {
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.02em;
    transition: color 0.3s ease;
  }
  .cli-cmd.revealed:hover .cli-text {
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.4) 0%,
      rgba(255, 255, 255, 0.4) 40%,
      rgba(255, 255, 255, 1) 44%,
      rgba(255, 255, 255, 1) 56%,
      rgba(255, 255, 255, 0.4) 60%,
      rgba(255, 255, 255, 0.4) 100%
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .cli-cmd:not(.revealed):hover .cli-text {
    color: rgba(255, 255, 255, 0.55);
  }
  .cli-cmd.copied .cli-text {
    animation: none !important;
    background: none !important;
    -webkit-background-clip: unset !important;
    background-clip: unset !important;
    -webkit-text-fill-color: unset !important;
    color: #1DB954 !important;
  }
  .cli-cmd.copied .cli-prompt {
    color: #1DB954;
  }
  .cli-icon {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.2);
    transition: color 0.3s ease;
  }
  .cli-cmd.revealed .cli-icon {
    color: rgba(255, 255, 255, 0.5);
  }
  .cli-cmd:hover .cli-icon {
    color: rgba(255, 255, 255, 0.6);
  }
  .cli-cmd.copied .cli-icon {
    color: #1DB954;
    animation: iconBounce 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes iconBounce {
    0% { transform: scale(0.5); }
    60% { transform: scale(1.3); }
    100% { transform: scale(1); }
  }
  :global(body.light-mode) .cli-cmd {
    background: rgba(0, 0, 0, 0.03);
    border-color: rgba(0, 0, 0, 0.12);
  }
  :global(body.light-mode) .cli-cmd:hover {
    background: rgba(0, 0, 0, 0.05);
    border-color: rgba(0, 0, 0, 0.18);
  }
  :global(body.light-mode) .cli-cmd.copied {
    border-color: rgba(29, 185, 84, 0.25);
    background: rgba(29, 185, 84, 0.05);
  }
  :global(body.light-mode) .cli-prompt {
    color: #0f4d1f;
  }
  :global(body.light-mode) .cli-text {
    color: rgba(0, 0, 0, 0.25);
  }
  :global(body.light-mode) .cli-cmd.copied .cli-text {
    color: #0f4d1f;
  }
  :global(body.light-mode) .cli-cmd.copied .cli-prompt {
    color: #0f4d1f;
  }
  :global(body.light-mode) .cli-cmd.revealed .cli-text {
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.18) 0%,
      rgba(0, 0, 0, 0.18) 40%,
      rgba(0, 0, 0, 0.85) 44%,
      rgba(0, 0, 0, 0.85) 56%,
      rgba(0, 0, 0, 0.18) 60%,
      rgba(0, 0, 0, 0.18) 100%
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  :global(body.light-mode) .cli-cmd.revealed:hover .cli-text {
    background: linear-gradient(
